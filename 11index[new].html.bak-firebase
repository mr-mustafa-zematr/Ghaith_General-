</div>

<div class="grades-section">
  <div class="sec-title reveal">
    <h2>اختر <span>مستواك</span></h2>
    <p>CHOOSE YOUR GRADE · PHYSICS 2026</p>
  </div>
  <div class="grades-grid">
    <div class="grade-card reveal" onclick="showLogin('student')">
      <div class="grade-num">I</div>
      <div class="grade-icon">⚡</div>
      <div class="grade-title">أولى ثانوي</div>
      <div class="grade-code">CODE: A-XXX</div>
      <div class="grade-sub">الصف الأول الثانوي — المنهج الجديد 2026</div>
      <ul class="grade-features">
        <li>ميكانيكا — الحركة والقوة</li>
        <li>الشغل والطاقة والقدرة</li>
        <li>الموجات الميكانيكية</li>
        <li>فيديوهات + كويزات + PDF</li>
      </ul>
      <div class="grade-price" id="price-first">اشتراك شهري</div>
      <button class="gbtn gbtn-1" onclick="buySubscription('first')">🛒 اشترك الآن</button>
    </div>
    <div class="grade-card reveal" onclick="showLogin('student')" style="transition-delay:0.1s">
      <div class="grade-num">II</div>
      <div class="grade-icon">🔬</div>
      <div class="grade-title">ثانية ثانوي</div>
      <div class="grade-code">CODE: B-XXX</div>
      <div class="grade-sub">الصف الثاني الثانوي — المنهج الجديد 2026</div>
      <ul class="grade-features">
        <li>الكهرباء الساكنة والتيار</li>
        <li>المغناطيسية والحث الكهرومغناطيسي</li>
        <li>الضوء والبصريات</li>
        <li>فيديوهات + كويزات + PDF</li>
      </ul>
      <div class="grade-price" id="price-second">اشتراك شهري</div>
      <button class="gbtn gbtn-2" onclick="buySubscription('second')">🛒 اشترك الآن</button>
    </div>
    <div class="grade-card reveal" onclick="showLogin('student')" style="transition-delay:0.2s">
      <div class="grade-num">III</div>
      <div class="grade-icon">🎯</div>
      <div class="grade-title">ثالثة ثانوي</div>
      <div class="grade-code">CODE: C-XXX</div>
      <div class="grade-sub">الصف الثالث الثانوي — ثانوية عامة 2026</div>
      <ul class="grade-features">
        <li>الفيزياء الحديثة والنووية</li>
        <li>مراجعة شاملة لكل المنهج</li>
        <li>أسئلة الامتحانات السابقة</li>
