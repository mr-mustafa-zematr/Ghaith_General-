<script>
// ===== THEME =====
function toggleTheme(){
  const t=document.documentElement.getAttribute('data-theme');
  const nt=t==='dark'?'light':'dark';
  document.documentElement.setAttribute('data-theme',nt);
  document.getElementById('theme-btn').textContent=nt==='dark'?'🌙':'☀️';
  localStorage.setItem('ghaith_theme',nt);
}
(function(){const t=localStorage.getItem('ghaith_theme')||'dark';document.documentElement.setAttribute('data-theme',t);setTimeout(()=>{const b=document.getElementById('theme-btn');if(b)b.textContent=t==='dark'?'🌙':'☀️';},100);})();

// ===== PHYSICS CANVAS =====
(function(){
  const c=document.getElementById('physics-canvas');
  const ctx=c.getContext('2d');
  let W,H;
  const particles=[];const waves=[];const formulas=['F=ma','E=mc²','v=λf','P=IV','ΔE=hf','F=qvB'];
  function resize(){W=c.width=window.innerWidth;H=c.height=window.innerHeight;}
  resize();window.addEventListener('resize',resize);
  for(let i=0;i<12;i++)particles.push({x:Math.random()*2000,y:Math.random()*1200,r:Math.random()*2+1,vx:(Math.random()-.5)*0.35,vy:(Math.random()-.5)*0.35,orb:Math.random()*25+15,angle:Math.random()*6.28,e:Math.floor(Math.random()*2)+1});
  for(let i=0;i<4;i++)waves.push({x:Math.random()*2000,y:Math.random()*1200,r:0,max:160,spd:0.7+Math.random()*0.4});
  function draw(){
    ctx.clearRect(0,0,W,H);
    const dark=document.documentElement.getAttribute('data-theme')==='dark';
    const col=dark?'224,16,16':'180,0,0';
    // Atoms
    particles.forEach(p=>{
      p.x+=p.vx;p.y+=p.vy;if(p.x<0||p.x>W)p.vx*=-1;if(p.y<0||p.y>H)p.vy*=-1;
      p.angle+=0.012;
      ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,6.28);ctx.fillStyle=`rgba(${col},0.7)`;ctx.fill();
      ctx.beginPath();ctx.arc(p.x,p.y,p.orb,0,6.28);ctx.strokeStyle=`rgba(${col},0.1)`;ctx.lineWidth=1;ctx.stroke();
      for(let e=0;e<p.e;e++){const a=p.angle+(e*6.28/p.e);ctx.beginPath();ctx.arc(p.x+Math.cos(a)*p.orb,p.y+Math.sin(a)*p.orb,1.5,0,6.28);ctx.fillStyle=`rgba(${col},0.6)`;ctx.fill();}
    });
    // Connections
    for(let i=0;i<particles.length;i++)for(let j=i+1;j<particles.length;j++){const d=Math.hypot(particles[i].x-particles[j].x,particles[i].y-particles[j].y);if(d<150){ctx.beginPath();ctx.moveTo(particles[i].x,particles[i].y);ctx.lineTo(particles[j].x,particles[j].y);ctx.strokeStyle=`rgba(${col},${(1-d/150)*0.07})`;ctx.lineWidth=1;ctx.stroke();}}
    // Waves
    waves.forEach(w=>{w.r+=w.spd;if(w.r>w.max){w.r=0;w.x=Math.random()*W;w.y=Math.random()*H;}const a=1-w.r/w.max;ctx.beginPath();ctx.arc(w.x,w.y,w.r,0,6.28);ctx.strokeStyle=`rgba(${col},${a*0.15})`;ctx.lineWidth=1.5;ctx.stroke();});
    requestAnimationFrame(draw);
  }
  draw();
})();

// ===== SCROLL REVEAL =====
const obs=new IntersectionObserver((entries)=>{entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target);}});},{threshold:0.1});
document.querySelectorAll('.reveal,.reveal-left,.reveal-right').forEach(el=>obs.observe(el));

